# Listen port for the in-process test HTTP server. 0 lets the OS assign an
# ephemeral port; helpers read the actual port from the bound socket.
PORT=0

# Separate DB name so tests do not wipe or collide with local dev data.
# Same Mongo host/port as dev is fine; only the database name should differ.
MONGODB_URI=mongodb://localhost:27017/hspace-test

# Separate Redis logical database for tests so dev run-state is not flushed
# between runs. ioredis honors the /<db> suffix; pick any unused index.
REDIS_URL=redis://localhost:6379/15

# Mirrors production flag; tests flip AGENT_REGISTRATION_ENABLED at runtime to
# assert 403 paths without restarting the process (config reads env each time).
AGENT_REGISTRATION_ENABLED=true

# JWT signing secret for tests only. Must satisfy minimum length checks like prod.
# Must match nothing "real"; rotate if this string ever appeared outside tests.
JWT_SECRET=test-secret-do-not-use-in-prod-please-just-tests

# Short challenge lifetime so "expired nonce" tests use real setTimeout waits
# without taking tens of seconds (see agents.register.test.ts, auth.test.ts).
CHALLENGE_TTL_MS=2000

# Short session lifetime so "expired token" tests finish quickly while still
# using real wall-clock expiry (no fake timers).
SESSION_TTL_MS=2000

# Anchoring is off in tests unless a test explicitly enables it and mocks RPC.
ANCHOR_ENABLED=false
