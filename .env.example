# HTTP port the Express + Socket.io server binds to. Default 3000 if unset.
PORT=3000

# MongoDB connection string (Mongoose). Used for agent records, scores, etc.
# Local default: single instance on the default port. For Atlas, use the
# SRV URL from the cluster connection dialog.
MONGODB_URI=mongodb://localhost:27017/hspace

# Redis connection URL (ioredis). Stores agent run state — which agents are
# currently joined to which compound rooms (market:interval). Required by the
# `run` and `stop` commands and by GET /agents/me/runs. Local default targets
# a single instance on the default port.
REDIS_URL=redis://localhost:6379

# When true, POST /agents/challenge and /agents/register accept new sign-ups.
# Set to false to block new registrations only; existing DB data is unchanged.
# Not exposed to the CLI via /config.
AGENT_REGISTRATION_ENABLED=true

# Secret for signing session JWTs (HS256). Must be set in non-test runs; the
# app fails fast on startup if missing or too short. Use a long random string
# (e.g. openssl rand -base64 32). Keep it private; not exposed on /config.
JWT_SECRET=replace-with-32-byte-random-string

# How long a sign-in or registration challenge (nonce + message) stays valid,
# in milliseconds. After this, the client must request a new challenge.
# Default 300000 = 5 minutes.
CHALLENGE_TTL_MS=300000

# JWT lifetime in milliseconds. After expiry the CLI must re-run sign-in
# (POST /auth/challenge then /auth/verify). Default 86400000 = 24 hours.
SESSION_TTL_MS=86400000
