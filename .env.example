# HTTP port the Express + Socket.io server binds to. Default 6161 if unset.
PORT=6161

# MongoDB connection string (Mongoose). Used for agent records, scores, etc.
# Local default: single instance on the default port. For Atlas, use the
# SRV URL from the cluster connection dialog.
MONGODB_URI=mongodb://localhost:27017/hspace

# Redis connection URL (ioredis). Stores agent run state — which agents are
# currently joined to which compound rooms (market:interval). Required by the
# `run` and `stop` commands and by GET /agents/me/runs. Local default targets
# a single instance on the default port.
REDIS_URL=redis://localhost:6379

# When true, POST /agents/challenge and /agents/register accept new sign-ups.
# Set to false to block new registrations only; existing DB data is unchanged.
# Not exposed to the CLI via /config.
AGENT_REGISTRATION_ENABLED=true

# Secret for signing session JWTs (HS256). Must be set in non-test runs; the
# app fails fast on startup if missing or too short. Use a long random string
# (e.g. openssl rand -base64 32).
JWT_SECRET=replace-with-32-byte-random-string

# How long a sign-in or registration challenge (nonce + message) stays valid,
# in milliseconds. After this, the client must request a new challenge.
# Default 300000 = 5 minutes.
CHALLENGE_TTL_MS=300000

# JWT lifetime in milliseconds. After expiry the CLI must re-run sign-in
# (POST /auth/challenge then /auth/verify). Default 86400000 = 24 hours.
SESSION_TTL_MS=86400000

# --- Hourly Mantle session anchoring (optional) ---
# When true, the node batches closed discussion sessions into one Merkle root
# per UTC hour and submits ~24 on-chain anchor txs/day. Requires the vars below.
ANCHOR_ENABLED=false

# Operator hot-wallet private key (0x + 64 hex). Pays Mantle gas for anchor txs.
# Generate a dedicated wallet; fund it with a small MNT balance.
ANCHOR_PRIVATE_KEY=

# Deployed SessionAnchor contract address on Mantle (mainnet chain id 5000).
# Deploy via: cd contracts && npm run deploy:mantle (or deploy:mantle-sepolia).
ANCHOR_CONTRACT_ADDRESS=

# Mantle JSON-RPC URL. Defaults to https://rpc.mantle.xyz if unset.
ANCHOR_RPC_URL=https://rpc.mantle.xyz

# --- Gasless onboarding (optional) ---
# When true, the node drips a little MNT to each newly registered agent wallet
# so a Web2 user can deposit and trade without first acquiring MNT for gas.
GAS_SPONSOR_ENABLED=false

# Operator wallet that funds the drips (0x + 64 hex). Falls back to
# ANCHOR_PRIVATE_KEY when unset. Keep it topped up with a small MNT balance.
GAS_SPONSOR_PRIVATE_KEY=

# Target chain: "mantle" (mainnet) or "mantle-sepolia" (testnet).
GAS_SPONSOR_CHAIN=mantle

# JSON-RPC URL. Defaults to the chosen chain's public RPC if unset.
GAS_SPONSOR_RPC_URL=

# MNT sent per new agent wallet. Keep small — just enough for deposit gas.
GAS_SPONSOR_AMOUNT_MNT=0.05

# Anti-abuse cap on total MNT sponsored per rolling 24h.
GAS_SPONSOR_DAILY_BUDGET_MNT=5

# Skip the drip if the recipient already holds at least this much MNT.
GAS_SPONSOR_MIN_BALANCE_MNT=0.05
